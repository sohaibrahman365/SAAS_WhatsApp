# ============================================================
# GeniSearch — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Anthropic (Claude AI) ──────────────────────────────────
# Used for: AI sentiment analysis & intent detection on WhatsApp replies
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp Cloud API ─────────────────────────────────────
# Used for: Sending/receiving WhatsApp messages
# Get from: https://developers.facebook.com/apps/ → WhatsApp → API Setup
WHATSAPP_API_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_BUSINESS_ACCOUNT_ID=9876543210987654
WHATSAPP_API_VERSION=v19.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_webhook_verify_token_here

# ── PostgreSQL Database ────────────────────────────────────
# Used for: All application data (tenants, campaigns, responses, customers)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://genisearch:password@localhost:5432/genisearch_db

# ── Google OAuth 2.0 ──────────────────────────────────────
# Used for: Super admin login (sohaib365@gmail.com) and tenant login
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── n8n Automation ────────────────────────────────────────
# Used for: CRM sync, Slack alerts, Google Sheets logging workflows
# Set up your n8n instance and add webhook URLs here
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/genisearch
N8N_API_KEY=your_n8n_api_key_here

# ── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# JWT secret for session tokens (generate: openssl rand -hex 64)
JWT_SECRET=your_very_long_random_secret_here_min_64_chars

# Super admin email (locked to this account)
SUPER_ADMIN_EMAIL=sohaib365@gmail.com

# ── Optional: Redis (for caching & rate limiting) ─────────
REDIS_URL=redis://localhost:6379
