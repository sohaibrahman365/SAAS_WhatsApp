# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/genisearch

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
SUPER_ADMIN_EMAIL=sohaib365@gmail.com

# Google OAuth (Phase 2 — leave blank for now)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── WhatsApp (Phase 4 — leave blank for now) ──────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v19.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=my_verify_token

# ── Anthropic / Claude AI (Phase 5 — leave blank for now) ─
ANTHROPIC_API_KEY=

# ── n8n Webhooks (Phase 7 — leave blank for now) ──────────
N8N_WEBHOOK_URL=
